# ── Production Caddyfile ──
# Single reverse-proxy to Next.js dev/prod server.
# The XTransformPort open-proxy block has been removed (SSRF fix P0-1).
# If dev port-forwarding is needed, use Caddyfile.dev (never deployed).

:81 {
	reverse_proxy localhost:3000 {
		header_up Host {host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}
